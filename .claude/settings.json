{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ENABLE_LSP_TOOL": "1",
    "MAX_THINKING_TOKENS": "16000",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "128000",
    "BASH_DEFAULT_TIMEOUT_MS": "120000",
    "BASH_MAX_TIMEOUT_MS": "600000",
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "API_TIMEOUT_MS": "3000000",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "ECC_MCP_HEALTH_FAIL_OPEN": "1"
  },
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run test:*)",
      "Bash(npm test:*)",
      "WebFetch",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push)",
      "Bash(git config:*)",
      "Bash(gh:*)",
      "Bash(node:*)",
      "Bash(which:*)",
      "Bash(pwd)",
      "Bash(ls:*)",
      "mcp__pencil",
      "Bash(jq:*)",
      "Bash(test:*)",
      "Bash(chmod:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git ls-tree:*)",
      "Bash(gh pr:*)",
      "Bash(gh pr list:*)",
      "Bash(sshpass -p 'super1gate@' ssh -o StrictHostKeyChecking=no jh.byun@192.168.35.8 \"echo '=== Current Ingress setup ===' && kubectl get ingressclass 2>/dev/null && echo && echo '=== Istio ingress ===' && kubectl get svc -n istio-system 2>/dev/null | head -5 && echo && echo '=== Helm repos ===' && helm repo list 2>/dev/null | head -10 && echo && echo '=== Available NodePorts ===' && kubectl get svc -A -o wide 2>/dev/null | grep -i nodeport | head -5\")"
    ],
    "deny": [
      "Bash(rm -rf /)"
    ],
    "ask": [],
    "defaultMode": "default"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": []
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c '\"/opt/homebrew/bin/node\" \"$(ls -td ~/.claude/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | head -1)dist/index.js\"'"
  },
  "enabledPlugins": {
    "claude-hud@claude-hud": true,
    "clarify@team-attention-plugins": true,
    "agent-council@team-attention-plugins": false,
    "code-review@claude-code-plugins": false,
    "everything-claude-code@everything-claude-code": true,
    "frontend-design@claude-code-plugins": false,
    "telegram@claude-plugins-official": true,
    "ui-ux-pro-max@ui-ux-pro-max-skill": false,
    "agent-skills@addy-agent-skills": true,
    "plannotator@plannotator": true,
    "obsidian@supergate-claude-plugin": true
  },
  "extraKnownMarketplaces": {
    "everything-claude-code": {
      "source": {
        "source": "github",
        "repo": "affaan-m/everything-claude-code"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "supergate-claude-plugin": {
      "source": {
        "source": "github",
        "repo": "supergate-hub/supergate-claude-plugin"
      }
    },
    "ui-ux-pro-max-skill": {
      "source": {
        "source": "github",
        "repo": "nextlevelbuilder/ui-ux-pro-max-skill"
      }
    },
    "addy-agent-skills": {
      "source": {
        "source": "github",
        "repo": "addyosmani/agent-skills"
      }
    },
    "plannotator": {
      "source": {
        "source": "github",
        "repo": "backnotprop/plannotator"
      }
    }
  },
  "language": "ko",
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "생각하는 중",
      "분석하는 중",
      "코드 읽는 중",
      "파일 탐색 중",
      "작성하는 중",
      "검토하는 중",
      "실행하는 중",
      "검색하는 중",
      "변경 적용 중",
      "테스트 확인 중",
      "구조 파악 중",
      "계획 수립 중",
      "의존성 추적 중",
      "리팩토링 중",
      "디버깅 중",
      "패턴 매칭 중",
      "컨텍스트 수집 중",
      "해결책 모색 중",
      "최적화 중",
      "연결고리 찾는 중"
    ]
  },
  "effortLevel": "xhigh",
  "autoMemoryEnabled": true,
  "autoDreamEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "mcpServers": {},
  "theme": "light",
  "editorMode": "vim",
  "verbose": true,
  "teammateMode": "tmux",
  "remoteControlAtStartup": true
}
